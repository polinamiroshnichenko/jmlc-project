### Поиск по каталогу — конкретный анализ
POST http://localhost:8000/chat/catalog-assistant HTTP/1.1
Content-Type: application/json

{
  "id": "topic-catalog-1",
  "state": "Active",
  "history": [
    {
      "id": "msg-1",
      "role": "User",
      "content": {
        "type": "ActionRequest",
        "action": "GetCatalogInfo",
        "text": "Общий анализ крови с лейкоцитарной формулой"
      },
      "createdAt": "2026-06-22T10:00:00Z"
    }
  ],
  "patient": {
    "id": "patient-1",
    "gender": "Male",
    "age": 40,
    "birthDate": "1986-04-10"
  },
  "language": "ru-ru",
  "serviceAttributes": {
    "callback_url": "http://host.docker.internal:9001/callback"
  }
}

