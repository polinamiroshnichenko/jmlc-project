        "type": "Text",
        "text": "При болях в пояснице после длительного сидения рекомендую консультацию невролога и МРТ поясничного отдела позвоночника. Также полезно сдать общий анализ крови и проверить уровень витамина D."
      },
      "createdAt": "2026-06-22T09:06:00Z",
      "model": "general-assistant"
    }
  ],
  "patient": {
    "id": "patient-3",
    "gender": "Male",
    "age": 40,
    "birthDate": "1986-11-20"
  },
  "language": "ru-ru",
